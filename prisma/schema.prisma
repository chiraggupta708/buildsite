generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts            Account[]
  sessions            Session[]
  clients             Client[]
  labours             Labour[]
  labourAssignments   LabourAssignment[]
  phases              Phase[]
  materialPurchases   MaterialPurchase[]
  labourPayments      LabourPayment[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Client {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  email     String?
  address   String?
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  sites Site[]

  @@index([userId])
}

model Site {
  id        String   @id @default(cuid())
  name      String
  address   String?
  status    String   @default("active")
  startDate DateTime?
  clientId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client            Client              @relation(fields: [clientId], references: [id], onDelete: Cascade)
  labourAssignments  LabourAssignment[]
  phases            Phase[]
  materialPurchases MaterialPurchase[]
  labourPayments    LabourPayment[]
  tasks             Task[]
  reminders         Reminder[]
}

model Labour {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  trade     String   @default("misc")
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignments LabourAssignment[]
  payments    LabourPayment[]
  tasks       Task[]

  @@index([userId])
}

model LabourAssignment {
  id        String    @id @default(cuid())
  labourId  String
  siteId    String
  startDate DateTime?
  endDate   DateTime?
  status    String    @default("active")
  userId    String
  createdAt DateTime  @default(now())

  labour Labour @relation(fields: [labourId], references: [id], onDelete: Cascade)
  site   Site   @relation(fields: [siteId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([labourId])
  @@index([siteId])
  @@index([userId])
}

model Phase {
  id        String   @id @default(cuid())
  name      String
  order     Int
  siteId    String
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  site     Site             @relation(fields: [siteId], references: [id], onDelete: Cascade)
  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  estimate PhaseEstimate?
  payments PhasePayment[]
  tasks    Task[]

  @@index([siteId])
  @@index([userId])
}

model PhaseEstimate {
  id         String   @id @default(cuid())
  phaseId    String   @unique
  supplier   String?
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  phase     Phase              @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  lineItems EstimateLineItem[]

  @@index([phaseId])
}

model EstimateLineItem {
  id          String   @id @default(cuid())
  estimateId  String
  description String
  uom         String
  quantity    Float
  ratePerUnit Float
  total       Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  estimate PhaseEstimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)

  @@index([estimateId])
}

model MaterialPurchase {
  id            String            @id @default(cuid())
  itemName      String
  uom           String
  quantity      Float
  ratePerUnit   Float
  total         Float
  purchaseDate  DateTime          @default(now())
  supplier      String?
  lowStockThreshold Float?
  siteId        String
  userId        String
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  site  Site            @relation(fields: [siteId], references: [id], onDelete: Cascade)
  user  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  usage MaterialUsage[]

  @@index([siteId])
  @@index([userId])
  @@index([itemName])
}

model MaterialUsage {
  id                 String   @id @default(cuid())
  quantityUsed       Float
  dateUsed           DateTime @default(now())
  materialPurchaseId String
  createdAt          DateTime @default(now())

  materialPurchase MaterialPurchase @relation(fields: [materialPurchaseId], references: [id], onDelete: Cascade)

  @@index([materialPurchaseId])
}

model LabourPayment {
  id        String   @id @default(cuid())
  labourId  String
  siteId    String
  amount    Float
  date      DateTime @default(now())
  notes     String?
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  labour Labour @relation(fields: [labourId], references: [id], onDelete: Cascade)
  site   Site   @relation(fields: [siteId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([labourId])
  @@index([siteId])
  @@index([userId])
}

model PhasePayment {
  id        String   @id @default(cuid())
  amount    Float
  date      DateTime @default(now())
  notes     String?
  phaseId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  phase Phase @relation(fields: [phaseId], references: [id], onDelete: Cascade)

  @@index([phaseId])
}

model Task {
  id          String   @id @default(cuid())
  title       String
  description String?
  status      String   @default("todo")
  order       Int      @default(0)
  siteId      String
  phaseId     String?
  labourId    String?
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  site   Site    @relation(fields: [siteId], references: [id], onDelete: Cascade)
  phase  Phase?  @relation(fields: [phaseId], references: [id], onDelete: SetNull)
  labour Labour? @relation(fields: [labourId], references: [id], onDelete: SetNull)

  @@index([siteId, status])
  @@index([userId])
}

model Reminder {
  id        String   @id @default(cuid())
  title     String
  message   String?
  dueDate   DateTime
  done      Boolean  @default(false)
  siteId    String
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([siteId])
  @@index([userId])
}